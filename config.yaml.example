# AI-DB-QC v6.0 Configuration File (YAML Format)
# Copy this file to config.yaml and adjust values

app:
  name: "AI-DB-QC v6"
  version: "6.0.0"

llm:
  provider: "deepseek"
  base_url: "https://api.deepseek.com"
  pro_model: "deepseek-v4-pro"
  flash_model: "deepseek-v4-flash"
  max_retries: 3
  timeout: 120
  thinking_mode: true
  reasoning_effort: "high"

database:
  type: "milvus"
  host: "localhost"
  port: 19530
  version: "2.6.12"

harness:
  max_rounds: 4
  max_token_budget: 2000000
  max_consecutive_failures: 5
  mre_clean_env: true
  mre_timeout: 60

docs:
  source: "local_jsonl"
  local_jsonl_path: ".trae/cache/milvus_io_docs_depth3.jsonl"
  crawl_max_depth: 3
  crawl_max_pages: 100

source_analysis:
  repo_url: "https://github.com/milvus-io/milvus.git"
  branch: "master"
  target_dir: ".trae/milvus_source"
  focus_dirs:
    - "internal/core/index"
    - "internal/core/search"
    - "internal/datacoord"
    - "internal/datanode"
    - "internal/querynode"
    - "internal/proxy"

output:
  issues_dir: ".trae/issues"
  state_dir: ".trae/runs"

logging:
  level: "INFO"
  telemetry_path: ".trae/runs/telemetry.jsonl"
